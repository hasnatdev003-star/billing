<?xml version="1.0" encoding="utf-8"?>
<!-- Monthly plan card: title + radio, price + period, description (grey), trial (purple). No BEST VALUE badge. -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/_2sdp">

    <LinearLayout
        android:id="@+id/card_plan"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_subscription_plan_card"
        android:clickable="true"
        android:elevation="0dp"
        android:focusable="true"
        android:paddingStart="12dp"
        android:paddingTop="10dp"
        android:paddingEnd="12dp"
        android:paddingBottom="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/layout_plan_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Title + Radio (same row) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_plan_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="Monthly Plan" />

                <androidx.appcompat.widget.AppCompatRadioButton
                    android:id="@+id/radio_plan"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:buttonTint="?attr/colorPrimary"
                    android:clickable="false"
                    android:focusable="false" />
            </LinearLayout>

            <!-- Price row: main price + cut price (strikethrough) next to it + period + save chip -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_plan_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    tools:text="150 PKR" />

                <TextView
                    android:id="@+id/tv_plan_original_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="12sp"
                    android:visibility="gone"
                    tools:text="199 PKR"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/tv_plan_period"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="1dp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="13sp"
                    tools:text=" / month" />

                <TextView
                    android:id="@+id/tv_plan_save"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_save_chip"
                    android:paddingStart="6dp"
                    android:paddingTop="3dp"
                    android:paddingEnd="6dp"
                    android:paddingBottom="3dp"
                    android:textColor="?attr/colorOnPrimary"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:text="SAVE 25%"
                    tools:visibility="visible" />
            </LinearLayout>

            <!-- Description (grey): e.g. "Cancel anytime" -->
            <TextView
                android:id="@+id/tv_plan_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="13sp"
                tools:text="Cancel anytime" />

            <!-- Trial / cancel (purple): e.g. "3-day free trial" -->
            <TextView
                android:id="@+id/tv_plan_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="?attr/colorPrimary"
                android:textSize="12sp"
                tools:text="3-day free trial" />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
