<?xml version="1.0" encoding="utf-8"?>
<!-- Dialog shown after successful subscription: title, description, Restart app button. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_dialog_subscription_success">

    <TextView
        android:id="@+id/dialog_subscription_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/subscription_success_dialog_title"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="?attr/colorPrimary"
        android:gravity="center"
        android:paddingBottom="12dp" />

    <TextView
        android:id="@+id/dialog_subscription_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/subscription_success_dialog_message"
        android:textSize="15sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:lineSpacingExtra="4dp"
        android:gravity="center"
        android:paddingBottom="20dp" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/dialog_subscription_btn_restart"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:text="@string/subscription_success_btn_restart"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnPrimary"
        android:background="@drawable/bg_subscription_success_button"
        android:paddingVertical="12dp" />
</LinearLayout>
